{
  "name": "project-bridge",
  "version": "1.5.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "verify-ast": "pnpm exec tsx ./packages/ast/src/bin/verify-ast.ts",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:smoke": "pnpm --filter e2e test:smoke",
    "test:e2e:headed": "pnpm --filter e2e test:headed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "husky": "^9.1.0",
    "playwright": "^1.58.2"
  }
}
